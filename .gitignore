# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
CLAUDE.md
AGENTS.md

# cloudflare / opennext
.open-next
.wrangler
.dev.vars
cloudflare-env.d.ts

# Claude Code 設定: 共有資産のみ追跡、個人設定とランタイム生成物は除外
.claude/*
!.claude/agents/
!.claude/commands/

# local temporary files
.tmp/
