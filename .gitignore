# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
CLAUDE.md
AGENTS.md

# cloudflare / opennext
.open-next
.wrangler
.dev.vars
cloudflare-env.d.ts

# Claude Code 設定: 共有資産のみ追跡、個人設定とランタイム生成物は除外
.claude/*
!.claude/agents/
!.claude/commands/

# local temporary files
.tmp/

# Supabase backup / dump files (絶対に git に含めない、本番 DB の機密データを含む可能性)
# 取得例: supabase db dump --db-url "$PROD_DB_URL" -f backup-prod-YYYYMMDD.sql
# pg_dump / supabase db dump 経由のファイルは安全な暗号化領域に保管し、git には push しない
backup-*.sql
dump-*.sql
*-backup.sql
